# ============================================================
# Dealyze — Variables d'environnement
# Copier ce fichier en .env et remplir les vraies valeurs
# ============================================================

# --- IA ---
GROQ_API_KEY=gsk_votre_cle_groq_ici

# --- Base de données ---
DATABASE_URL=sqlite:///./dealyze.db

# --- JWT ---
JWT_SECRET_KEY=generer_avec: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Lemon Squeezy (paiements réels — fonctionne depuis le Bénin) ---
# 1. Créer un compte sur https://lemonsqueezy.com
# 2. Settings → API → Générer une clé API
LEMONSQUEEZY_API_KEY=your_api_key_here
# 3. Dashboard → ton store → copier l'ID (chiffre dans l'URL)
LEMONSQUEEZY_STORE_ID=12345
# 4. Settings → Webhooks → Add webhook → copier la Signing Secret
LEMONSQUEEZY_WEBHOOK_SECRET=your_signing_secret_here
# 5. Products → créer 3 produits → copier les Variant IDs
LS_VARIANT_STARTER=123456      # 47 USD/mois
LS_VARIANT_GROWTH=123457       # 147 USD/mois
LS_VARIANT_ENTERPRISE=123458   # 477 USD/mois

# --- Mode simulation ---
# true  = pas besoin de compte LS, le paiement est simulé (parfait pour hackathon)
# false = paiements réels via Lemon Squeezy
SIMULATION_MODE=true

# --- App ---
APP_URL=http://localhost:3000
APP_ENV=development
